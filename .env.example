# ============================================================================
# AGENTIC COMPLIANCE PLATFORM - ENVIRONMENT CONFIG
# ============================================================================

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
APP_NAME=AgenticComplianceOS
ENVIRONMENT=development
DEBUG=True

# ----------------------------------------------------------------------------
# API SERVER
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ----------------------------------------------------------------------------
# OPENAI
# ----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# LANGCHAIN / LANGGRAPH
# ----------------------------------------------------------------------------
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-compliance

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite:///agentic_compliance.db

# PostgreSQL (future production)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentic_compliance

# ----------------------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ----------------------------------------------------------------------------
# VECTOR DATABASE (QDRANT)
# ----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=audit_memory

# ----------------------------------------------------------------------------
# DOCUMENT PROCESSING
# ----------------------------------------------------------------------------
UNSTRUCTURED_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ----------------------------------------------------------------------------
# HITL (HUMAN-IN-THE-LOOP)
# ----------------------------------------------------------------------------
HITL_ENABLED=true
HITL_TIMEOUT_MINUTES=1440

# ----------------------------------------------------------------------------
# STORAGE
# ----------------------------------------------------------------------------
UPLOAD_DIR=uploads
CHECKPOINT_DIR=checkpoints
LOG_DIR=logs
REPORT_DIR=reports

# ----------------------------------------------------------------------------
# OBSERVABILITY
# ----------------------------------------------------------------------------
ENABLE_OBSERVABILITY=true
TRACE_LOG_FILE=logs/traces.jsonl
METRICS_FILE=logs/metrics.json

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
JWT_SECRET=change_this_in_production
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
ENABLE_MOCK_OCR=true
ENABLE_REAL_OCR=false
ENABLE_QDRANT=false
ENABLE_LANGGRAPH=false

# ----------------------------------------------------------------------------
# COMPLIANCE SETTINGS
# ----------------------------------------------------------------------------
DEFAULT_COMPLIANCE_FRAMEWORK=SOC2
MAX_UPLOAD_MB=50
ALLOWED_FILE_TYPES=pdf,docx

# ----------------------------------------------------------------------------
# REPORT GENERATION
# ----------------------------------------------------------------------------
REPORT_TEMPLATE=consulting
COMPANY_NAME=Praman